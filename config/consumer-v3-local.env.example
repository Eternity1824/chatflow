# consumer-v3 local development environment variables
# For local dev against a Docker-compose RabbitMQ + LocalStack DynamoDB/SQS.
#
# Usage (bash/zsh):
#   set -a && source config/consumer-v3-local.env.example && set +a

# ── RabbitMQ (local Docker) ───────────────────────────────────────────────────
CHATFLOW_V3_RABBIT_HOST=localhost
CHATFLOW_V3_RABBIT_PORT=5672
CHATFLOW_V3_RABBIT_USERNAME=guest
CHATFLOW_V3_RABBIT_PASSWORD=guest
CHATFLOW_V3_RABBIT_VHOST=/
CHATFLOW_V3_RABBIT_EXCHANGE=chat.exchange
CHATFLOW_V3_RABBIT_PREFETCH=50

# ── DynamoDB (LocalStack) ─────────────────────────────────────────────────────
CHATFLOW_V3_DYNAMO_REGION=us-east-1
CHATFLOW_V3_DYNAMO_TABLE_CANONICAL=messages_by_id
# Override endpoint for LocalStack: set AWS_ENDPOINT_URL=http://localhost:4566

# ── SQS DLQ (LocalStack) ──────────────────────────────────────────────────────
CHATFLOW_V3_SQS_DLQ_URL=http://localhost:4566/000000000000/chatflow-consumer-v3-dlq

# ── Batch / flush ─────────────────────────────────────────────────────────────
CHATFLOW_V3_BATCH_SIZE=20
CHATFLOW_V3_FLUSH_INTERVAL_MS=1000
CHATFLOW_V3_SEMAPHORE_PERMITS=8

# ── Retry ─────────────────────────────────────────────────────────────────────
CHATFLOW_V3_RETRY_BASE_MS=100
CHATFLOW_V3_RETRY_MAX_MS=3000
CHATFLOW_V3_MAX_RETRIES=3

# ── Observability ─────────────────────────────────────────────────────────────
CHATFLOW_V3_METRICS_PORT=8091
CHATFLOW_V3_METRICS_LOG_INTERVAL_MS=10000
