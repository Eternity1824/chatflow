aws_region   = "us-west-2"
name_prefix  = "chatflow-a2"
environment  = "assignment2"

# Set your own office/home public IP CIDR for SSH and admin UIs.
# Example: ["203.0.113.10/32"]
admin_cidrs = []

# Optional: if you have an EC2 key pair.
key_name = ""

# Assignment load-balanced scenarios: set to 1, 2, then 4 for tests.
server_count   = 4
consumer_count = 4

server_instance_type   = "t3.small"
consumer_instance_type = "t3.small"
rabbit_instance_type   = "t3.small"

# Internal server gRPC port for consumer fan-out.
server_grpc_port = 9090

# Consumer internal broadcast format:
# - "grpc" => "server-private-ip:9090"
# - "http" => "http://server-private-ip:8080"
consumer_broadcast_mode = "grpc"
consumer_threads        = 80
consumer_prefetch       = 200
consumer_room_max_inflight   = 16
consumer_global_max_inflight = 2000

chatflow_internal_token = "replace-with-strong-token"
rabbit_username         = "guest"
rabbit_password         = "guest"

# Recommended deployment mode: container images.
rabbit_image   = "rabbitmq:3-management"
server_image   = "ghcr.io/<user>/chatflow-server-v2:<tag>"
consumer_image = "ghcr.io/<user>/chatflow-consumer-v3:<tag>"

# Assignment 3 persistence stack.
# enable_persistence       = true
# enable_elasticache       = true
# If your AWS lab account cannot create IAM roles, reuse the pre-created lab identities instead.
# existing_server_instance_profile_name   = "LabInstanceProfile"
# existing_consumer_instance_profile_name = "LabInstanceProfile"
# existing_lambda_role_arn                = "arn:aws:iam::<account-id>:role/LabRole"
# lambda_cdc_jar_s3_bucket = "<your-bucket>"
# lambda_cdc_jar_s3_key    = "chatflow/projection-lambda-all.jar"
# lambda_cdc_jar_local_path = "../projection-lambda/build/libs/projection-lambda-1.0-SNAPSHOT-all.jar"
# elasticache_subnet_ids   = ["subnet-xxxx", "subnet-yyyy"]
# consumer_v3_batch_size   = 1000
# consumer_v3_flush_interval_ms = 500
# consumer_v3_semaphore_permits = 64

# Optional jar fallback mode (used only if image is empty).
# server_jar_url   = "https://<bucket-or-host>/server-v2-all.jar"
# consumer_jar_url = "https://<bucket-or-host>/consumer-all.jar"
